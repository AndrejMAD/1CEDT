Функция ОбновитьИлиСоздать(ДанныеAPI)
	
	Группа = ОбновитьИлиСоздатьГруппу(ДанныеAPI);
	
	Объект = Неопределено;
	Ссылка = НайтиПоКоду(ДанныеAPI.КодЭлемента, Истина, Группа);
	
	Если Ссылка = Неопределено ИЛИ Ссылка.Пустая() Тогда
		Объект = СоздатьЭлемент();
	Иначе
		Объект = Ссылка.ПолучитьОбъект();
	КонецЕсли;
	
	Объект.Родитель = Группа;
	Объект.Код = ДанныеAPI.КодЭлемента;
	Объект.Наименование = ДанныеAPI.НаименованиеЭлемента;
	
	Объект.Записать();
	Возврат Объект.Ссылка;
	
КонецФункции

Функция ОбновитьИлиСоздатьГруппу(ДанныеAPI)
	
	Объект = Неопределено;
	Ссылка = НайтиПоКоду(ДанныеAPI.КодГруппы, Истина);
	
	Если Ссылка = Неопределено ИЛИ Ссылка.Пустая() Тогда
		Объект = СоздатьГруппу();
	Иначе
		Объект = Ссылка.ПолучитьОбъект();
	КонецЕсли;
	
	Объект.Код = ДанныеAPI.КодГруппы;
	Объект.Наименование = ДанныеAPI.НаименованиеГруппы;
	
	Объект.Записать();
	Возврат Объект.Ссылка;
	
КонецФункции

#КонецОбласти

#КонецЕсли
