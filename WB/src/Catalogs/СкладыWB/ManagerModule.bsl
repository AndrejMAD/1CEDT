#Область ПрограммныйИнтерфейс

Процедура ЗагрузитьВсе() Экспорт
	
	Токен = КлиентAPI.ПолучитьТокенAPI();
	
	ДанныеAPI = ПоставкиAPI.ПолучитьСписокСкладов(Токен);
	ДанныеAPI = МаппингЗначений.ПрименитьМаппинг(ДанныеAPI, ПолучитьПараметрыМаппинга());
	
	Если ДанныеAPI = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ЭлементAPI Из ДанныеAPI Цикл
		ОбновитьИлиСоздать(ЭлементAPI);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

