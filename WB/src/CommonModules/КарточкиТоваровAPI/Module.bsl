
#Область ПрограммныйИнтерфейс

Функция ПолучитьВсеКарточкиТоваров(Токен, Язык = "ru") Экспорт
	
	ВсеКарточкиТоваров = Новый Массив;
	
	ПроверкаЗначенийКлиентСервер.ПроверитьЗначениеЗаполнено(Токен, Тип("Строка"));
	ПроверкаЗначенийКлиентСервер.ПроверитьЗначениеЗаполнено(Язык, Тип("Строка"));
	
	НачальнаяДата = Неопределено;
	НачальныйАртикулWB = Неопределено;
	Количество = 0;
	Лимит = 100;
	
	Пока Истина Цикл
		
		ДанныеAPI = ПолучитьКарточкиТоваров(Токен, НачальнаяДата, НачальныйАртикулWB, Лимит, Язык);
		
		КарточкиТоваров = Неопределено;
		Если ДанныеAPI.Свойство("cards", КарточкиТоваров) Тогда
			Для Каждого Элемент Из КарточкиТоваров Цикл
				ВсеКарточкиТоваров.Добавить(Элемент);
			КонецЦикла;
		КонецЕсли;
		
		Курсор = Неопределено;
		Если ДанныеAPI.Свойство("cursor", Курсор) Тогда
			Количество = Курсор.total;
			НачальнаяДата = Курсор.updatedAt;
			НачальныйАртикулWB = Курсор.nmID;
		КонецЕсли;
		
		Если Количество < Лимит Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ВсеКарточкиТоваров;
	
КонецФункции

#КонецОбласти

