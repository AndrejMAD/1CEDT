#Область СлужебныеПроцедурыИФункции

Функция ПолучитьКарточкиТоваров(Токен, НачальнаяДата = Неопределено, НачальныйАртикулWB = Неопределено, Лимит = 100, Язык = "ru") Экспорт
	
	ПроверкаЗначенийКлиентСервер.ПроверитьЗначениеЗаполнено(Токен, Тип("Строка"));
	ПроверкаЗначенийКлиентСервер.ПроверитьЗначениеЗаполнено(Язык, Тип("Строка"));
	ПроверкаЗначенийКлиентСервер.ПроверитьЧисло(Лимит, 1, 100);
	
	АдресСервера = КлиентAPI.СерверКонтента();
	Путь = "/content/v2/get/cards/list";
	
	ПараметрыЗапросаURL = Новый Структура;
	ПараметрыЗапросаURL.Вставить("locale", Язык);
	
	ПараметрыЗапросаJSON = Новый Структура;
	ПараметрыЗапросаJSONНастройки = Новый Структура;
	ПараметрыЗапросаJSONФильтр = Новый Структура;
	ПараметрыЗапросаJSONСортировка = Новый Структура;
	ПараметрыЗапросаJSONКурсор = Новый Структура;
	
	ПараметрыЗапросаJSON.Вставить("settings", ПараметрыЗапросаJSONНастройки);
	
	ПараметрыЗапросаJSONНастройки.Вставить("filter", ПараметрыЗапросаJSONФильтр);
	ПараметрыЗапросаJSONНастройки.Вставить("sort", ПараметрыЗапросаJSONСортировка);
	ПараметрыЗапросаJSONНастройки.Вставить("cursor", ПараметрыЗапросаJSONКурсор);
	
	ПараметрыЗапросаJSONФильтр.Вставить("withPhoto", -1);
	ПараметрыЗапросаJSONСортировка.Вставить("ascending", Истина);
	ПараметрыЗапросаJSONКурсор.Вставить("limit", Лимит);
	
	Если НачальнаяДата <> Неопределено Тогда
		ПроверкаЗначенийКлиентСервер.ПроверитьЗначениеЗаполнено(НачальнаяДата, Тип("Дата"));
		ПараметрыЗапросаJSONКурсор.Вставить("updatedAt", НачальнаяДата);
	КонецЕсли;
	
	Если НачальныйАртикулWB <> Неопределено Тогда
		ПроверкаЗначенийКлиентСервер.ПроверитьЗначениеЗаполнено(НачальныйАртикулWB, Тип("Число"));
		ПараметрыЗапросаJSONКурсор.Вставить("nmID", НачальныйАртикулWB);
	КонецЕсли;

	ДанныеAPI = КлиентAPI.ВыполнитьЗапрос(Токен, АдресСервера, Перечисления.ВидHTTPЗапроса.POST, Путь, ПараметрыЗапросаURL, ПараметрыЗапросаJSON);
	
	Возврат МаппингЗначений.ПрименитьМаппинг(ДанныеAPI, ПолучитьПараметрыМаппинга());;
	
КонецФункции

Функция ПолучитьПараметрыМаппинга()
	
	ПараметрыМаппинга = Новый Структура;
	// Артикул WB
	ПараметрыМаппинга.Вставить("nmID", Новый Структура("ИмяКлюча, ТипЗначения", "АртикулWB", Тип("Число")));
	// ID для объединённых карточек товаров
	ПараметрыМаппинга.Вставить("imtID", Новый Структура("ИмяКлюча, ТипЗначения", "ИдОбъединеннойКарточки", Тип("Число")));
	// Внутренний технический ID карточки товара
	ПараметрыМаппинга.Вставить("nmUUID", Новый Структура("ИмяКлюча, ТипЗначения", "ИдВнутренний", Тип("Строка")));
	// ID предмета
	ПараметрыМаппинга.Вставить("subjectID", Новый Структура("ИмяКлюча, ТипЗначения", "ИдКатегории", Тип("Число")));
	// Название предмета
	ПараметрыМаппинга.Вставить("subjectName", Новый Структура("ИмяКлюча, ТипЗначения", "НаименованиеКатегории", Тип("Строка")));
	// Артикул продавца
	ПараметрыМаппинга.Вставить("vendorCode", Новый Структура("ИмяКлюча, ТипЗначения", "АртикулПродавца", Тип("Строка")));
	// Бренд
	ПараметрыМаппинга.Вставить("brand", Новый Структура("ИмяКлюча, ТипЗначения", "Бренд", Тип("Строка")));
	// Наименование товараы
	ПараметрыМаппинга.Вставить("title", Новый Структура("ИмяКлюча, ТипЗначения", "Наименование", Тип("Строка")));
	// Описание товара
	ПараметрыМаппинга.Вставить("description", Новый Структура("ИмяКлюча, ТипЗначения", "Описание", Тип("Строка")));
	// Требуется ли код маркировки
	ПараметрыМаппинга.Вставить("needKiz", Новый Структура("ИмяКлюча, ТипЗначения", "ТребуетсяКодМаркировки", Тип("Булево")));
	// Есть ли подтверждение о нанесении кода маркировки
	ПараметрыМаппинга.Вставить("kizMarked", Новый Структура("ИмяКлюча, ТипЗначения", "КодМаркировкиНанесен", Тип("Булево")));
	// Массив фото
	ПараметрыМаппинга.Вставить("photos", Новый Структура(
		"ИмяКлюча, ТипЗначения, ПараметрыМаппинга", 
		"Медиафайлы", Тип("Структура"), ПолучитьПараметрыМаппингаФото()));
	// Оптовая продажа
	ПараметрыМаппинга.Вставить("wholesale", Новый Структура(
		"ИмяКлюча, ТипЗначения, ПараметрыМаппинга", 
		"ОптоваяПродажа", Тип("Структура"), ПолучитьПараметрыМаппингаОпт()));
	// Габариты и вес товара
	ПараметрыМаппинга.Вставить("dimensions", Новый Структура(
		"ИмяКлюча, ТипЗначения, ПараметрыМаппинга", 
		"Габариты", Тип("Структура"), ПолучитьПараметрыМаппингаГабариты()));
	// Характеристики
	ПараметрыМаппинга.Вставить("characteristics", Новый Структура(
		"ИмяКлюча, ТипЗначения, ПараметрыМаппинга", 
		"Характеристики", Тип("Структура"), ПолучитьПараметрыМаппингаХарактеристики()));
	// Размеры товара
	ПараметрыМаппинга.Вставить("sizes", Новый Структура(
		"ИмяКлюча, ТипЗначения, ПараметрыМаппинга", 
		"Размеры", Тип("Структура"), ПолучитьПараметрыМаппингаРазмеры()));
	// Ярлыки
	ПараметрыМаппинга.Вставить("tags", Новый Структура(
		"ИмяКлюча, ТипЗначения, ПараметрыМаппинга", 
		"Ярлыки", Тип("Структура"), ПолучитьПараметрыМаппингаЯрлыки()));
	// Дата и время создания
	ПараметрыМаппинга.Вставить("createdAt", Новый Структура("ИмяКлюча, ТипЗначения", "ДатаСоздания", Тип("Дата")));
	// Дата и время изменения
	ПараметрыМаппинга.Вставить("updatedAt", Новый Структура("ИмяКлюча, ТипЗначения", "ДатаИзменения", Тип("Дата")));
	
	Возврат ПараметрыМаппинга;
	
КонецФункции

Функция ПолучитьПараметрыМаппингаФото()
	
	Параметры = Новый Структура;
	// URL фото 900x1200
	Параметры.Вставить("big", Новый Структура("ИмяКлюча, ТипЗначения", "ФотоБольшое", Тип("Строка")));
	// URL фото 248x328
	Параметры.Вставить("c246x328", Новый Структура("ИмяКлюча, ТипЗначения", "ФотоМалое", Тип("Строка")));
	// URL фото 516x688
	Параметры.Вставить("c516x688", Новый Структура("ИмяКлюча, ТипЗначения", "ФотоСреднее", Тип("Строка")));
	// URL фото 600x600
	Параметры.Вставить("square", Новый Структура("ИмяКлюча, ТипЗначения", "ФотоКвадрат", Тип("Строка")));
	// URL фото 75x100
	Параметры.Вставить("tm", Новый Структура("ИмяКлюча, ТипЗначения", "ФотоМиниатюра", Тип("Строка")));
	// URL видео
	Параметры.Вставить("video", Новый Структура("ИмяКлюча, ТипЗначения", "Видео", Тип("Строка")));
	
	Возврат Параметры;
	
КонецФункции

Функция ПолучитьПараметрыМаппингаОпт()
	
	Параметры = Новый Структура;
	// Предназначена ли карточка для оптовой продажи
	Параметры.Вставить("enabled", Новый Структура("ИмяКлюча, ТипЗначения", "ОптовыеПродажи", Тип("Булево")));
	// Количество единиц товара в упаковке
	Параметры.Вставить("quantum", Новый Структура("ИмяКлюча, ТипЗначения", "КоличествоВУпаковке", Тип("Число")));
	
	Возврат Параметры;
	
КонецФункции

