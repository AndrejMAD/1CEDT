#Область ПрограммныйИнтерфейс

Функция ВыполнитьЗапрос(Токен, АдресСервера, ВидЗапроса, Путь, ПараметрыURL = Неопределено, ПараметрыJSON = Неопределено,
	ПараметрыМаппинга = Неопределено) Экспорт
	
	// Проверка входных параметров
	ПроверкаЗначенийКлиентСервер.ПроверитьЗначениеЗаполнено(Токен, Тип("Строка"));
	ПроверкаЗначенийКлиентСервер.ПроверитьЗначениеЗаполнено(АдресСервера, Тип("Строка"));
	ПроверкаЗначенийКлиентСервер.ПроверитьЗначениеЗаполнено(ВидЗапроса, Тип("ПеречислениеСсылка.ВидHTTPЗапроса"));
	ПроверкаЗначенийКлиентСервер.ПроверитьЗначениеЗаполнено(Путь, Тип("Строка"));

	Таймаут = 30;

	Если ПараметрыURL <> Неопределено Тогда
		Путь = Путь + "?" + СтруктураВПараметрыURL(ПараметрыURL);
	КонецЕсли;

	ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL;
	Соединение = Новый HTTPСоединение(АдресСервера, , , , , Таймаут, ЗащищенноеСоединение);
	Запрос = Новый HTTPЗапрос(Путь);
	Запрос.Заголовки.Вставить("Authorization", Токен);
	Запрос.Заголовки.Вставить("Content-Type", "application/json");
	Запрос.Заголовки.Вставить("Accept", "application/json");

	Если ПараметрыJSON <> Неопределено Тогда
		СтрокаJSON = ПарсерJSON.ПолучитьJSON(ПараметрыJSON);
		Запрос.УстановитьТелоИзСтроки(СтрокаJSON);
	КонецЕсли;

	Ответ = Неопределено;

	Попытка
		Если ВидЗапроса = Перечисления.ВидHTTPЗапроса.GET Тогда
			Ответ = Соединение.Получить(Запрос);
		ИначеЕсли ВидЗапроса = Перечисления.ВидHTTPЗапроса.POST Тогда
			Ответ = Соединение.ОтправитьДляОбработки(Запрос);
		ИначеЕсли ВидЗапроса = Перечисления.ВидHTTPЗапроса.PATCH Тогда
			Ответ = Соединение.Изменить(Запрос);
		ИначеЕсли ВидЗапроса = Перечисления.ВидHTTPЗапроса.DELETE Тогда
			Ответ = Соединение.Удалить(Запрос);
		Иначе
			ВызватьИсключение("Неподдерживаемый вид HTTP-запроса", КатегорияОшибки.ОшибкаКонфигурации);
		КонецЕсли;
	Исключение
		ВызватьИсключение
	КонецПопытки;
	
	Если Ответ = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	КодСостояния = Ответ.КодСостояния;

	Если КодСостояния = 200 Тогда
		Возврат ПарсерJSON.ПолучитьЗначение(Ответ.ПолучитьТелоКакСтроку(), ПараметрыМаппинга);
	ИначеЕсли КодСостояния = 204 Тогда
		Возврат Неопределено
	Иначе
		ОбработатьОшибку(Ответ);
	КонецЕсли;
	
КонецФункции

#КонецОбласти

