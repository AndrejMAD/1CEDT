
#Область ПрограммныйИнтерфейс

Функция ПолучитьВсеДетализациюОтчетаРеализации(Токен, ИдОтчета) Экспорт
	
	ПроверкаЗначенийКлиентСервер.ПроверитьЗначениеЗаполнено(Токен, Тип("Строка"));
	ПроверкаЗначенийКлиентСервер.ПроверитьЗначениеЗаполнено(ИдОтчета, Тип("Число"));
	
	Результат = Новый Массив;
	
	Лимит = 100000;
	ИдПоследнийСтроки = 0;
	
	Пока Истина Цикл
		
		ДанныеAPI = ПолучитьДетализациюОтчетаРеализации(Токен, ИдОтчета, Лимит, ИдПоследнийСтроки);
		
		Если ДанныеAPI = Неопределено ИЛИ ДанныеAPI.Количество() = 0 Тогда
			Возврат Результат;
		КонецЕсли;
		
		Для Каждого ЭлементAPI Из ДанныеAPI Цикл
			Результат.Добавить(ЭлементAPI);
		КонецЦикла;
		
		ПоследнийЭлементAPI = Результат.Получить(Результат.Количество() - 1);
		ИдПоследнийСтроки = ПоследнийЭлементAPI.ИдСтроки;
		
	КонецЦикла;
	
КонецФункции

Функция ПолучитьДетализациюОтчетаРеализации(Токен, ИдОтчета, Лимит = 100000, ИдПоследнийСтроки = 0, Поля = Неопределено) Экспорт
	
	ПроверкаЗначенийКлиентСервер.ПроверитьЗначениеЗаполнено(Токен, Тип("Строка"));
	ПроверкаЗначенийКлиентСервер.ПроверитьЗначениеЗаполнено(ИдОтчета, Тип("Число"));
	
	АдресСервера = КлиентAPI.СерверФинансов();
	Путь = "/api/finance/v1/sales-reports/detailed/" + Формат(ИдОтчета, "ЧГ=0;");
	
	ПараметрыJSON = Новый Структура;
	ПараметрыJSON.Вставить("limit", Лимит);
	ПараметрыJSON.Вставить("rrdId", ИдПоследнийСтроки);
	
	Если Поля <> Неопределено Тогда
		ПараметрыJSON.Вставить("fields", Поля);
	КонецЕсли;

	ДанныеAPI = КлиентAPI.ВыполнитьЗапрос(Токен, АдресСервера, Перечисления.ТипыHTTPЗапроса.POST, Путь, , ПараметрыJSON);
	Возврат МаппингЗначений.ПрименитьМаппинг(ДанныеAPI, ПолучитьПараметрыМаппингаДетализацииОтчетаРеализации());
	
КонецФункции

Функция ПолучитьВсеЕжедневныеОтчетыРеализации(Токен, НачалоПериода, КонецПериода = Неопределено) Экспорт

	Если КонецПериода = Неопределено Тогда
		КонецПериода = ТекущаяДатаСеанса();
	КонецЕсли;

	Результат = Новый Массив;

	ПроверкаЗначенийКлиентСервер.ПроверитьЗначениеЗаполнено(Токен, Тип("Строка"));
	ПроверкаЗначенийКлиентСервер.ПроверитьЗначениеЗаполнено(НачалоПериода, Тип("Дата"));
	ПроверкаЗначенийКлиентСервер.ПроверитьЗначениеЗаполнено(КонецПериода, Тип("Дата"));

	Лимит = 1000;
	Смещение = 0;

	Пока Истина Цикл

		ДанныеAPI = ПолучитьЕжедневныеОтчетыРеализации(Токен, НачалоПериода, КонецПериода, Лимит, Смещение);
		
		Если ДанныеAPI = Неопределено Тогда
			Возврат Результат;
		КонецЕсли;

		Для Каждого ЭлементAPI Из ДанныеAPI Цикл
			Результат.Добавить(ЭлементAPI);
		КонецЦикла;

		Если ДанныеAPI.Количество() < Лимит Тогда
			Прервать;
		КонецЕсли;

		Смещение = Смещение + Лимит;

	КонецЦикла;

	Возврат Результат;

КонецФункции

Функция ПолучитьЕжедневныеОтчетыРеализации(Токен, НачалоПериода, КонецПериода, Лимит = 1000, Смещение = 0) Экспорт
	
	// Проверка входных параметров
	ПроверкаЗначенийКлиентСервер.ПроверитьЗначениеЗаполнено(Токен, Тип("Строка"));
	ПроверкаЗначенийКлиентСервер.ПроверитьПериод(НачалоПериода, КонецПериода);
	ПроверкаЗначенийКлиентСервер.ПроверитьЧисло(Лимит, 1, 1000);
	ПроверкаЗначенийКлиентСервер.ПроверитьЧисло(Смещение, 0);
	
	АдресСервера = КлиентAPI.СерверФинансов();
	Путь = "/api/finance/v1/sales-reports/list";
	ПериодичностьОтчета = "daily";
	
	ПараметрыJSON = Новый Структура;
	ПараметрыJSON.Вставить("dateFrom", НачалоПериода);
	ПараметрыJSON.Вставить("dateTo", КонецПериода);
	ПараметрыJSON.Вставить("limit", Лимит);
	ПараметрыJSON.Вставить("offset", Смещение);
	ПараметрыJSON.Вставить("period", ПериодичностьОтчета);

	ДанныеAPI = КлиентAPI.ВыполнитьЗапрос(Токен, АдресСервера, Перечисления.ТипыHTTPЗапроса.POST, Путь, , ПараметрыJSON);
	Возврат МаппингЗначений.ПрименитьМаппинг(ДанныеAPI, ПолучитьПараметрыМаппингаОтчетаРеализации());
	
КонецФункции

