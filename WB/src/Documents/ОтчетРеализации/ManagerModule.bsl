
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

Функция ВыбратьДатуПоследнегоДокумента(Продавец) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ОтчетРеализации.Дата КАК Дата
	|ИЗ
	|	Документ.ОтчетРеализации КАК ОтчетРеализации
	|ГДЕ
	|	ОтчетРеализации.Продавец = &Продавец
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата УБЫВ";
	
	Запрос.УстановитьПараметр("Продавец", Продавец);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка.Дата;
	
КонецФункции

Процедура ЗагрузитьВсе() Экспорт
	
	Продавцы = Справочники.Продавцы.ВыбратьВсехПродавцов();
	
	Для Каждого Продавец Из Продавцы Цикл
		ЗагрузитьПоПродавцу(Продавец);
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗагрузитьПоПродавцу(Продавец) Экспорт
	
	НачалоПериода = ПолучитьНачалоПериодаЗагрузки(Продавец);
	Загрузить(Продавец, НачалоПериода);
	
КонецПроцедуры

Процедура Загрузить(Продавец, НачалоПериода, КонецПериода = Неопределено) Экспорт
	
	Токен = Справочники.Продавцы.ПолучитьТокен(Продавец);
	
	ПроверкаЗначенийКлиентСервер.ПроверитьЗначениеЗаполнено(Токен, Тип("Строка"));
	ПроверкаЗначенийКлиентСервер.ПроверитьЗначениеЗаполнено(Продавец, Тип("СправочникСсылка.Продавцы"));
	
	ДанныеAPI = ОтчетыРеализацииAPI.ПолучитьВсеЕжедневныеОтчетыРеализации(Токен, НачалоПериода, КонецПериода);
	
	Если ДанныеAPI = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ЭлементAPI Из ДанныеAPI Цикл
		ОбновитьИлиСоздать(ЭлементAPI, Продавец);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытий

// Код процедур и функций

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ОбновитьИлиСоздать(ДанныеAPI, Продавец)
	
	Объект = Неопределено;
	Ссылка = НайтиПоРеквизиту("ИдОтчета", ДанныеAPI.ИдОтчета);
	
	Если Ссылка = Неопределено ИЛИ Ссылка.Пустая() Тогда
		Объект = СоздатьДокумент();
	Иначе
		Объект = Ссылка.ПолучитьОбъект();
	КонецЕсли;
	
	Объект.Продавец = Продавец;
	ЗаполнитьИзДанныхAPI(Объект, ДанныеAPI);
	
	Объект.Записать();
	Возврат Объект.Ссылка;
	
КонецФункции

Процедура ЗаполнитьИзДанныхAPI(Объект, ДанныеAPI)
	
	Объект.Дата = ДанныеAPI.Дата;
	Объект.ИдОтчета = ДанныеAPI.ИдОтчета;
	Объект.НачалоПериода = ДанныеAPI.НачалоПериода;
	Объект.КонецПериода = ДанныеAPI.КонецПериода;
	Объект.Валюта = Справочники.Валюты.ПолучитьПоНаименованию(ДанныеAPI.Валюта);
	Объект.ВидОтчета = Перечисления.ВидыОтчетаРеализации.Значение(ДанныеAPI.ВидОтчета);
	Объект.СуммаПродаж = ДанныеAPI.СуммаПродаж;
	Объект.СуммаКПеречислению = ДанныеAPI.СуммаКПеречислению;
	Объект.ПроцентСогласованнойСкидки = ДанныеAPI.ПроцентСогласованнойСкидки;
	Объект.СтоимостьЛогистики = ДанныеAPI.СтоимостьЛогистики;
	Объект.СтоимостьХранения = ДанныеAPI.СтоимостьХранения;
	Объект.СтоимостьПриемки = ДанныеAPI.СтоимостьПриемки;
	Объект.СуммаПрочихУдержаний = ДанныеAPI.СуммаПрочихУдержаний;
	Объект.СуммаШтрафов = ДанныеAPI.СуммаШтрафов;
	Объект.СуммаКорректировкиВознаграждения = ДанныеAPI.СуммаКорректировкиВознаграждения;
	Объект.СуммаУдержанияЗаБаллы = ДанныеAPI.СуммаУдержанияЗаБаллы;
	Объект.СуммаКомпенсацииСкидкиЛояльности = ДанныеAPI.СуммаКомпенсацииСкидкиЛояльности;
	Объект.СтоимостьУчастияВЛояльности = ДанныеAPI.СтоимостьУчастияВЛояльности;
	Объект.СтоимостьИзмененияСрокаПеречисления = ДанныеAPI.СтоимостьИзмененияСрокаПеречисления;
	Объект.СуммаКОплате = ДанныеAPI.СуммаКОплате;

КонецПроцедуры

Функция ПолучитьНачалоПериодаЗагрузки(Продавец)
	
	ДатаПоследнегоДокумента = ВыбратьДатуПоследнегоДокумента(Продавец);
	
	Если ДатаПоследнегоДокумента <> Неопределено Тогда
		Возврат ДатаПоследнегоДокумента;
	КонецЕсли;
	
	Возврат Справочники.Продавцы.ПолучитьДатуРегистрации(Продавец);

КонецФункции

#КонецОбласти

#КонецЕсли
