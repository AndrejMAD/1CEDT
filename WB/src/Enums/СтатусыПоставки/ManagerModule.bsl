Функция ПолучитьПоИд(Ид) Экспорт

	Если Ид = 1 Тогда
		Возврат НеЗапланировано;
	ИначеЕсли Ид = 2 Тогда
		Возврат Запланировано;
	ИначеЕсли Ид = 3 Тогда
		Возврат ОтгрузкаРазрешена;
	ИначеЕсли Ид = 4 Тогда
		Возврат ИдетПриемка;
	ИначеЕсли Ид = 5 Тогда
		Возврат Принято;
	ИначеЕсли Ид = 6 Тогда
		Возврат ОтгруженоНаВоротах;
	Иначе
		Возврат Неопределено;
	КонецЕсли;

КонецФункции